hcloud_token = "your-hetzner-api-token"

# Customize as needed:
# cluster_name        = "k8s-lab"
# locations           = ["fsn1", "nbg1", "hel1"]  # nodes distributed round-robin
# server_type         = "cx23"
# control_plane_count = 3        # 1 = single CP, 3 = HA
# worker_count        = 1
# k8s_version         = "1.35"
# ssh_key_name        = "k8s-admin"
# ssh_public_key_path = "~/.ssh/id_ed25519.pub"
# allowed_ips         = ["YOUR.IP.HERE/32"]  # restricts SSH + API access
