apiVersion: kubeadm.k8s.io/v1beta3
kind: InitConfiguration
localAPIEndpoint:
  advertiseAddress: "{{ internal_ip }}"
  bindPort: 6443
nodeRegistration:
  kubeletExtraArgs:
    node-ip: "{{ internal_ip }}"
---
apiVersion: kubeadm.k8s.io/v1beta3
kind: ClusterConfiguration
kubernetesVersion: stable
controlPlaneEndpoint: "{{ lb_ip }}:6443"
networking:
  podSubnet: "{{ pod_cidr }}"
  serviceSubnet: "{{ service_cidr }}"
apiServer:
  certSANs:
    - "{{ lb_ip }}"
{% for host in groups['control_plane'] %}
    - "{{ hostvars[host]['ansible_host'] }}"
    - "{{ hostvars[host]['internal_ip'] }}"
{% endfor %}
